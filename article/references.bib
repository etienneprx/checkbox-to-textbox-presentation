  shorttitle = {Ain’t No Party like a {{GPT}} Party},
  author = {M. Foisy, Laurence-Olivier and Drouin, Jérémie and Pelletier, Camille and Rivest, Jozef and Cadieux, Hubert and Dufresne, Yannick},
